# 复制为 .env 并按环境修改

# 应用
APP_NAME=中外法学智能编审系统
DEBUG=false

# 数据库（不设置 DATABASE_URL 则默认 SQLite，可直接 python -m scripts.init_db）
# 若未安装/未启动 PostgreSQL，请设 USE_SQLITE=true 使用 SQLite
# USE_SQLITE=true
# 生产请用 PostgreSQL，且必须为同步驱动 postgresql://（勿用 postgresql+asyncpg，否则 init_db 会报错）
# DATABASE_URL=postgresql://user:password@localhost:5432/law_review

# 认证
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 文件存储（初版本地）
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./storage

# 跨域（前端开发地址）
CORS_ORIGINS=["http://localhost:3000"]

# 阿里云百炼（大模型调用，用于 AI 初审报告等）
# 在阿里云百炼控制台创建 API Key，填入下方；本地不用 AI 可留空
DASHSCOPE_API_KEY=
# 华北2（北京）默认如下；新加坡: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 模型名，如 qwen3.5-plus / qwen3-max-2026-01-23 / qwen3-coder-next
LLM_MODEL=qwen3.5-plus
# EasyScholar 期刊级别查询密钥（用于引注评级）
EASY_SCHOLAR_SECRET=
